# ============================================
# Neurascape Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
# IMPORTANT: If these credentials have ever been exposed,
# rotate ALL of them immediately.
# ============================================

# Flask
FLASK_ENV=development
SECRET_KEY=generate-a-strong-random-key-here

# Admin
ADMIN_PASSWORD=your-strong-admin-password

# Email (Brevo transactional email)
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=your-email@example.com
MAIL_RECIPIENT=your-email@example.com
BREVO_API_KEY=your-brevo-api-key

# Spotify OAuth
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/spotify/callback

# Sentry error monitoring (free tier: 5K errors/month)
# SENTRY_DSN=https:"https://3d24ae852e39f9b49f4fe31125ef2b20@o4511072078200832.ingest.de.sentry.io/4511072080953424",

# Database (Neon PostgreSQL) — only needed in production
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# DigitalOcean Spaces (S3-compatible) — only needed in production
# DO_SPACE_KEY=your-spaces-access-key
# DO_SPACE_SECRET=your-spaces-secret-key
# DO_SPACE_NAME=your-space-name
# DO_SPACE_REGION=your-region
